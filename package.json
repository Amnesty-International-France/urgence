{
    "private": true,
    "workspaces": [
        "amnesty-components",
        "api",
        "front",
        "admin"
    ],
    "devDependencies": {
        "cypress": "^12.9.0",
        "jest": "~22.4.4",
        "jest-canvas-mock": "~2.0.0",
        "jest-cli": "~22.4.4"
    },
    "scripts": {
        "test": "NODE_ENV=test jest --ci --forceExit",
        "test-watch": "NODE_ENV=test jest --watch"
    },
    "jest": {
        "setupFiles": [
            "jest-canvas-mock",
            "./setup-test"
        ],
        "restoreMocks": true,
        "resetMocks": true,
        "moduleDirectories": [
            "node_modules",
            "front/node_modules",
            "api/node_modules"
        ],
        "testEnvironment": "jsdom",
        "testURL": "http://localhost",
        "testPathIgnorePatterns": [
            "node_modules",
            "e2e",
            "api/dist",
            "front/scripts/"
        ],
        "moduleNameMapper": {
            "\\.svg$": "<rootDir>/__mocks__/svgMock.js",
            "\\.css$": "<rootDir>/__mocks__/styleMock.js"
        }
    },
    "packageManager": "yarn@3.2.1",
    "engines": {
        "node": "^18"
    }
}
