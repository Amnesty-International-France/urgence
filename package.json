{
  "dependencies": {
    "convict": "4.2.0",
    "express-graphql": "0.6.12",
    "graphql": "0.13.2",
    "graphql-tag": "2.8.0",
    "redux-form": "^7.3.0"
  },
  "scripts": {
    "test": "jest --ci --forceExit",
    "test-watch": "jest --watch"
  },
  "devDependencies": {
    "jest": "22.4.3",
    "jest-canvas-mock": "1.0.2",
    "jest-cli": "22.4.3",
    "shipit-cli": "4.0.2",
    "shipit-deploy": "4.0.2",
    "uuid-by-string": "0.6.0"
  },
  "jest": {
    "setupFiles": [
      "jest-canvas-mock",
      "./setup-test"
    ],
    "moduleDirectories": [
      "node_modules",
      "front/node_modules",
      "api/node_modules"
    ],
    "testEnvironment": "jsdom",
    "testPathIgnorePatterns": [
      "node_modules",
      "e2e"
    ],
    "moduleNameMapper": {
      "\\.(css)$": "<rootDir>/__mocks__/styleMock.js"
    }
