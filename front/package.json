{
    "name": "urgent_reaction",
    "version": "0.1.0",
    "private": true,
    "main": "./node_modules/react-native-scripts/build/bin/crna-entry.js",
    "scripts": {
        "start-web": "node scripts/start.js",
        "build-web": "node scripts/build.js",
        "test-web": "node scripts/test.js --env=jsdom",
        "eject-web": "node scripts/eject.js",
        "start-native": "react-native-scripts start",
        "eject-native": "react-native-scripts eject",
        "android": "react-native-scripts android",
        "ios": "react-native-scripts ios",
        "test-native": "node node_modules/jest/bin/jest.js --watch",
        "test": "npm run test-web && npm run test-native",
        "test-e2e": "jest ./e2e",
        "storybook": "start-storybook -p 9009 -s public",
        "build-storybook": "build-storybook -s public"
    },
    "dependencies": {
        "apollo-boost": "^0.1.4",
        "apollo-link-schema": "^1.1.0",
        "autoprefixer": "7.1.6",
        "babel-polyfill": "^6.26.0",
        "case-sensitive-paths-webpack-plugin": "2.1.1",
        "chalk": "1.1.3",
        "classnames": "^2.2.5",
        "css-loader": "0.28.7",
        "dotenv": "4.0.0",
        "dotenv-expand": "4.2.0",
        "eslint": "4.10.0",
        "eslint-config-react-app": "^2.1.0",
        "eslint-loader": "1.9.0",
        "eslint-plugin-flowtype": "2.39.1",
        "eslint-plugin-import": "2.8.0",
        "eslint-plugin-jsx-a11y": "5.1.1",
        "eslint-plugin-react": "7.4.0",
        "expo": "^25.0.0",
        "extract-text-webpack-plugin": "3.0.2",
        "file-loader": "1.1.5",
        "fs-extra": "3.0.1",
        "glamorous": "^4.12.1",
        "glamorous-primitives": "^2.1.3",
        "graphql": "^0.13.2",
        "graphql-tag": "^2.9.1",
        "html-webpack-plugin": "2.29.0",
        "lodash.get": "^4.4.2",
        "object-assign": "4.1.1",
        "postcss-flexbugs-fixes": "3.2.0",
        "postcss-loader": "2.0.8",
        "promise": "8.0.1",
        "qs": "^6.5.2",
        "raf": "3.4.0",
        "ramda": "0.25.0",
        "react": "^16.3.2",
        "react-apollo": "^2.1.3",
        "react-dev-utils": "^5.0.1",
        "react-div-100vh": "^0.1.8",
        "react-dom": "^16.3.2",
        "react-native": "^0.52.0",
        "react-native-web": "^0.5.4",
        "react-primitives": "^0.5.0",
        "react-router": "^4.2.0",
        "react-router-dom": "^4.2.2",
        "react-router-native": "^4.2.0",
        "react-slick": "^0.23.1",
        "react-id-swiper": "^1.6.4",
        "react-transition-group": "^2.3.1",
        "recompose": "^0.27.1",
        "resolve": "1.6.0",
        "slick-carousel": "^1.8.1",
        "style-loader": "0.19.0",
        "sw-precache-webpack-plugin": "0.11.4",
        "url-loader": "0.6.2",
        "webpack": "3.8.1",
        "webpack-dev-server": "2.9.4",
        "webpack-manifest-plugin": "1.3.2",
        "whatwg-fetch": "2.0.3"
    },
    "devDependencies": {
        "@storybook/addon-actions": "^3.4.1",
        "@storybook/addon-links": "^3.4.1",
        "@storybook/addons": "^3.4.1",
        "@storybook/react": "^3.4.1",
        "apollo-test-utils": "^0.3.2",
        "babel-core": "^6.26.0",
        "babel-eslint": "7.2.3",
        "babel-jest": "^22.4.3",
        "babel-loader": "7.1.2",
        "babel-plugin-transform-class-properties": "^6.24.1",
        "babel-plugin-transform-object-rest-spread": "^6.26.0",
        "babel-plugin-transform-react-jsx-source": "^6.22.0",
        "babel-preset-expo": "^4.0.0",
        "babel-preset-react-app": "^3.1.1",
        "babel-runtime": "^6.26.0",
        "enzyme": "^3.3.0",
        "enzyme-adapter-react-16": "^1.1.1",
        "eslint": "^4.19.1",
        "eslint-config-prettier": "^2.9.0",
        "eslint-import-resolver-node": "^0.3.2",
        "eslint-plugin-import": "^2.8.0",
        "eslint-plugin-jest": "^21.15.0",
        "eslint-plugin-jsx-a11y": "^6.0.3",
        "eslint-plugin-mocha": "^4.11.0",
        "eslint-plugin-mocha-no-only": "^0.0.6",
        "eslint-plugin-prettier": "^2.6.0",
        "eslint-plugin-react": "^7.6.1",
        "jest": "^22.4.3",
        "prettier": "^1.12.0",
        "react-native-scripts": "^1.12.1",
        "react-test-renderer": "^16.2.0",
        "selenium-webdriver": "^3.6.0",
        "storybook-react-router": "^1.0.1",
        "unfetch": "^3.0.0"
    },
    "jest": {
        "collectCoverageFrom": [
            "src/**/*.{js,jsx,mjs}"
        ],
        "setupTestFrameworkScriptFile": "<rootDir>/config/setupTest.js",
        "setupFiles": [
            "babel-polyfill",
            "<rootDir>/config/polyfills.js"
        ],
        "testMatch": [
            "<rootDir>/src/**/__tests__/**/*.{js,jsx,mjs}",
            "<rootDir>/src/**/?(*.)(spec|test).{js,jsx,mjs}",
            "<rootDir>/e2e/**/?(*.)(spec|test).{js,jsx,mjs}"
        ],
        "testEnvironment": "node",
        "testURL": "http://localhost",
        "transform": {
            "^.+\\.(js|jsx|mjs)$": "<rootDir>/node_modules/babel-jest",
            "^.+\\.css$": "<rootDir>/config/jest/cssTransform.js",
            "^(?!.*\\.(js|jsx|mjs|css|json)$)": "<rootDir>/config/jest/fileTransform.js"
        },
        "transformIgnorePatterns": [
            "[/\\\\]node_modules[/\\\\].+\\.(js|jsx|mjs)$"
        ],
        "moduleNameMapper": {
            "^react-native$": "react-native-web"
        },
        "moduleFileExtensions": [
            "web.js",
            "js",
            "json",
            "web.jsx",
            "jsx",
            "node",
            "mjs"
        ]
    },
    "babel": {
        "presets": [
            "react-app"
        ]
    },
    "eslintConfig": {
        "extends": "react-app"
    }
}
